# ── Required

# Telegram bot token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN

# ndus cookie value from terabox.com
# 1. Log in at https://www.terabox.com
# 2. DevTools → Application → Cookies → terabox.com → copy "ndus"
NDUS_COOKIE=your_ndus_cookie_value_here

# Telegram API credentials from https://my.telegram.org
# Required for uploading files larger than 50 MB via MTProto
API_ID=12345678
API_HASH=abcdefghijklmnopqrstuvwxyz

# ── Optionala

# Owner Pyrogram session string — enables 4 GB uploads (instead of default 2 GB)
# Generate with: python -c "from pyrogram import Client; Client('s').run()"
# Leave empty to use bot-only MTProto (2 GB limit)

SESSION_STRING=

# Cache resolved links for this many seconds (default: 2 hours)
CACHE_TTL=7200

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO